{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "ova:start-server",
      "type": "shell",
      "command": "npm.cmd run serve",
      "windows": {
        "command": "npm.cmd run serve"
      },
      "linux": {
        "command": "npm run serve"
      },
      "osx": {
        "command": "npm run serve"
      },
      "options": {
        "cwd": "${workspaceFolder}"
      },
      "isBackground": true,
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "focus": false
      },
      "problemMatcher": {
        "owner": "ova",
        "pattern": {
          "regexp": "^$",
          "file": 1,
          "location": 2,
          "message": 3
        },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "OVA servidor escuchando"
        }
      }
    }
  ]
}
